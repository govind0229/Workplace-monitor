<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Workplace Monitor</title>
    <organization>com.workplacemonitor.app</organization>
    <domains enable_localSystem="true" />
    <options customize="never" require-scripts="true" rootVolumeOnly="true" />

    <!-- Minimum macOS version (Big Sur 11.0 for Apple Silicon support) -->
    <allowed-os-versions>
        <os-version min="11.0" />
    </allowed-os-versions>

    <!-- Welcome / Readme (optional — uncomment and provide files) -->
    <!-- <welcome    file="welcome.html"  mime-type="text/html" /> -->
    <!-- <readme     file="readme.html"   mime-type="text/html" /> -->
    <!-- <license    file="license.html"  mime-type="text/html" /> -->

    <choices-outline>
        <line choice="default">
            <line choice="com.workplacemonitor.app.pkg" />
        </line>
    </choices-outline>

    <choice id="default" />

    <choice id="com.workplacemonitor.app.pkg"
            visible="false"
            customLocation="/Applications">
        <pkg-ref id="com.workplacemonitor.app.pkg" />
    </choice>

    <pkg-ref id="com.workplacemonitor.app.pkg"
             version="2.0.2"
             onConclusion="none">WorkplaceMonitor-component.pkg</pkg-ref>

</installer-gui-script>
